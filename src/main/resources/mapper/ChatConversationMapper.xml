<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.cosx.chat.mapper.ChatConversationMapper">

    <resultMap id="BaseResultMap" type="cn.cosx.chat.entity.ChatConversation">
        <id column="id" property="id"/>
        <result column="conversation_id" property="conversationId"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="lock_version" property="lockVersion"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="BaseColumnList">
        id, conversation_id, user_id, title, created_time, updated_time, lock_version, deleted
    </sql>

</mapper>
